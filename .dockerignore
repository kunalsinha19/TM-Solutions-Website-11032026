# Git metadata (never needed)
.git

# Build outputs
.next
apps/web/.next
apps/api/.next
frontend/.next

# Dependencies (reinstalled inside Docker)
node_modules
apps/web/node_modules
apps/api/node_modules
frontend/node_modules
backend/node_modules
admin/node_modules

# Backend — not needed to build the Next.js frontend image
# The backend service uses its own Dockerfile at backend/Dockerfile
backend/

# Admin source — only admin/package.json is needed (npm workspace manifest)
# The admin Vite app is not part of the Next.js build
admin/src
admin/public
admin/index.html
admin/vite.config.js
admin/tsconfig*.json

# Frontend legacy directory — only package.json needed for workspace
frontend/src
frontend/scripts
frontend/public

# Logs and secrets
npm-debug.log*
.env*.local
