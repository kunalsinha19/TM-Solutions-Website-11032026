{
  "name": "tara-maa-solutions",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "install:frontend": "npm --prefix frontend install",
    "install:backend": "npm --prefix backend install",
    "install:all": "npm run install:frontend && npm run install:backend",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "npm --prefix backend run build",
    "build:prod": "npm run build:frontend && npm run build:backend",
    "start:frontend": "npm --prefix frontend run start:prod",
    "start:backend": "npm --prefix backend run start:prod"
  }
}
